{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://inneranimalmedia.com",
          "https://www.inneranimalmedia.com",
          "http://localhost:5173",
          "http://localhost:8787"
        ],
        "methods": ["GET", "HEAD"],
        "headers": ["range", "content-type"]
      },
      "exposeHeaders": ["Content-Length", "Content-Range", "Accept-Ranges", "ETag"],
      "maxAgeSeconds": 3600
    }
  ]
}
