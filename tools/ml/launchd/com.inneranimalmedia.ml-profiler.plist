<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Install (once):
    cp tools/ml/launchd/com.inneranimalmedia.ml-profiler.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.inneranimalmedia.ml-profiler.plist

  Daily at 04:15 local. Calendar job only (not KeepAlive).
-->
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.inneranimalmedia.ml-profiler</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>/Users/samprimeaux/inneranimalmedia/tools/ml/run_daily.sh</string>
	</array>
	<key>WorkingDirectory</key>
	<string>/Users/samprimeaux/inneranimalmedia/tools/ml</string>
	<key>StartCalendarInterval</key>
	<dict>
		<key>Hour</key>
		<integer>4</integer>
		<key>Minute</key>
		<integer>15</integer>
	</dict>
	<key>StandardOutPath</key>
	<string>/Users/samprimeaux/Library/Logs/inneranimalmedia-ml-profiler.out.log</string>
	<key>StandardErrorPath</key>
	<string>/Users/samprimeaux/Library/Logs/inneranimalmedia-ml-profiler.err.log</string>
</dict>
</plist>
