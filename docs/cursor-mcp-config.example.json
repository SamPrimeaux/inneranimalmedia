{
  "_comment": "Documentation only — merge into YOUR .cursor/mcp.json by hand; do not let agents overwrite that file.",
  "mcpServers": {
    "inneranimalmedia": {
      "url": "https://mcp.inneranimalmedia.com/mcp",
      "auth": {
        "type": "oauth",
        "authorizationUrl": "https://inneranimalmedia.com/api/oauth/authorize",
        "tokenUrl": "https://inneranimalmedia.com/api/oauth/token",
        "clientId": "iam_mcp_inneranimalmedia",
        "scopes": ["mcp:tools", "iam:agent"]
      }
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    "gemini-api-docs-mcp": {
      "url": "https://gemini-api-docs-mcp.dev"
    }
  }
}
