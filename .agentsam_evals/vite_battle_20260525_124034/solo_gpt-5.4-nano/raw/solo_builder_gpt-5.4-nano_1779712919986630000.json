            "text": "{\n  \"files\": [\n    {\n      \"path\": \"package.json\",\n      \"content\": \"{\\n  \\\"name\\\": \\\"agent-sam-command-center\\\",\\n  \\\"private\\\": true,\\n  \\\"version\\\": \\\"1.0.0\\\",\\n  \\\"type\\\": \\\"module\\\",\\n  \\\"scripts\\\": {\\n    \\\"dev\\\": \\\"vite\\\",\\n    \\\"build\\\": \\\"vite build\\\",\\n    \\\"preview\\\": \\\"vite preview\\\"\\n  },\\n  \\\"dependencies\\\": {\\n    \\\"react\\\": \\\"^18.3.1\\\",\\n    \\\"react-dom\\\": \\\"^18.3.1\\\"\\n  },\\n  \\\"devDependencies\\\": {\\n    \\\"@types/react\\\": \\\"^18.3.3\\\",\\n    \\\"@types/react-dom\\\": \\\"^18.3.0\\\",\\n    \\\"@vitejs/plugin-react\\\": \\\"^4.3.1\\\",\\n    \\\"typescript\\\": \\\"^5.5.4\\\",\\n    \\\"vite\\\": \\\"^5.4.2\\\"\\n  }\\n}\\n\"\n    },\n    {\n      \"path\": \"index.html\",\n      \"content\": \"<!doctype html>\\n<html lang=\\\"en\\\">\\n  <head>\\n    <meta charset=\\\"UTF-8\\\" />\\n    <meta name=\\\"viewport\\\" content=\\\"width=device-width, initial-scale=1.0\\\" />\\n    <title>Agent Sam Command Center</title>\\n  </head>\\n  <body>\\n    <div id=\\\"root\\\"></div>\\n    <script type=\\\"module\\\" src=\\\"/src/main.tsx\\\"></script>\\n  </body>\\n</html>\\n\"\n    },\n    {\n      \"path\": \"src/main.tsx\",\n      \"content\": \"import React from 'react'\\nimport ReactDOM from 'react-dom/client'\\nimport App from './App'\\n\\nReactDOM.createRoot(document.getElementById('root')!).render(\\n  <React.StrictMode>\\n    <App />\\n  </React.StrictMode>,\\n)\\n\"\n    },\n    {\n      \"path\": \"src/App.tsx\",\n      \"content\": \"import React, { useEffect, useMemo, useState } from 'react'\\nimport './App.css'\\n\\ntype PageKey = 'overview' | 'routing' | 'eval'\\n\\ntype ModelCandidate = {\\n  name: string\\n  flavor: 'beta' | 'gamma' | 'stable'\\n  passRate: number\\n  latencyMs: number\\n  costPer1k: number\\n  notes: string\\n}\\n\\nconst clamp = (n: number, min: number, max: number) => Math.max(min, Math.min(max, n))\\n\\nfunction formatMoney(n: number) {\\n  return n.toLocaleString(undefined, { style: 'currency', currency: 'USD', maximumFractionDigits: 2 })\\n}\\n\\nfunction formatMs(n: number) {\\n  return `${Math.round(n)} ms`\\n}\\n\\nfunction ProgressBar({ value, label }: { value: number; label?: string }) {\\n  const pct = clamp(value, 0, 100)\\n  return (\\n    <div className=\\\"pb\\\">\\n      <div className=\\\"pbTop\\\">\\n        {label ? <div className=\\\"pbLabel\\\">{label}</div> : <div />}\\n        <div className=\\\"pbValue\\\">{pct.toFixed(1)}%</div>\\n      </div>\\n      <div className=\\\"pbTrack\\\" aria-hidden=\\\"true\\\">\\n        <div className=\\\"pbFill\\\" style={{ width: `${pct}%` }} />\\n      </div>\\n    </div>\\n  )\\n}\\n\\nfunction MetricCard({\\n  title,\\n  value,\\n  sub,\\n  tone,\\n  icon,\\n}: {\\n  title: string\\n  value: string\\n  sub: string\\n  tone: 'good' | 'warn' | 'bad' | 'info'\\n  icon: string\\n}) {\\n  return (\\n    <div className={`card metric tone-${tone}`} role=\\\"group\\\" aria-label={title}>\\n      <div className=\\\"metricIcon\\\" aria-hidden=\\\"true\\\">\\n        {icon}\\n      </div>\\n      <div className=\\\"metricBody\\\">\\n        <div className=\\\"metricTitle\\\">{title}</div>\\n        <div className=\\\"metricValue\\\">{value}</div>\\n        <div className=\\\"metricSub\\\">{sub}</div>\\n      </div>\\n    </div>\\n  )\\n}\\n\\nfunction StatPill({ label, value, tone }: { label: string; value: string; tone: 'good' | 'warn' | 'bad' | 'info' }) {\\n  return (\\n    <div className={`pill tone-${tone}`}>\\n      <span className=\\\"pillLabel\\\">{label}</span>\\n      <span className=\\\"pillValue\\\">{value}</span>\\n    </div>\\n  )\\n}\\n\\nexport default function App() {\\n  const [page, setPage] = useState<PageKey>('overview')\\n  const [compactNav, setCompactNav] = useState(false)\\n\\n  useEffect(() => {\\n    const onResize = () => setCompactNav(window.innerWidth < 900)\\n    onResize()\\n    window.addEventListener('resize', onResize)\\n    return () => window.removeEventListener('resize', onResize)\\n  }, [])\\n\\n  useEffect(() => {\\n    const onKey = (e: KeyboardEvent) => {\\n      if (e.key === '1') setPage('overview')\\n      if (e.key === '2') setPage('routing')\\n      if (e.key === '3') setPage('eval')\\n    }\\n    window.addEventListener('keydown', onKey)\\n    return () => window.removeEventListener('keydown', onKey)\\n  }, [])\\n\\n  const data = useMemo(() => {\\n    // Mock metrics for Thompson routing\\n    const thompson = {\\n      passRate: 92.6,\\n      passRateDelta: +3.1,\\n      latencyMs: 284,\\n      latencyDelta: -18,\\n      costPer1k: 0.87,\\n      costDelta: -0.12,\\n      alpha: 12.4,\\n      beta: 4.6,\\n      confidence: 78.2,\\n      modelCandidates: [\\n        {\\n          name: 'gpt-5.3-codex',\\n          flavor: 'stable',\\n          passRate: 90.8,\\n          latencyMs: 305,\\n          costPer1k: 1.05,\\n          notes: 'Great at long-context code fixes; slightly higher tail latency.',\\n        },\\n        {\\n          name: 'gpt-5.4-mini',\\n          flavor: 'beta',\\n          passRate: 93.7,\\n          latencyMs: 268,\\n          costPer1k: 0.78,\\n          notes: 'Best balance for daily workloads; strong success on routing prompts.',\\n        },\\n        {\\n          name: 'gpt-5.4-nano',\\n          flavor: 'gamma',\\n          passRate: 86.1,\\n          latencyMs: 214,\\n          costPer1k: 0.42,\\n          notes: 'Lowest cost and fastest; used for trivial tasks and short diffs.',\\n        },\\n      ] satisfies ModelCandidate[],\\n    }\\n\\n    return {\\n      thompson,\\n      routingLab: {\\n        scenarios: [\\n          { name: 'Hotfix Patch', traffic: '34%', target: 'Max pass rate', alpha: 13.1, beta: 4.2 },\\n          { name: 'Refactor Suggest', traffic: '41%', target: 'Min latency', alpha: 11.9, beta: 4.9 },\\n          { name: 'Doc Upgrade', traffic: '25%', target: 'Min cost', alpha: 10.7, beta: 5.4 },\\n        ],\\n      },\\n      evalReport: {\\n        overview: {\\n          runs: 1840,\\n          suites: 6,\\n          bestModel: 'gpt-5.4-mini',\\n          score: 0.91,\\n        },\\n        breakdown: [\\n          { label: 'Functional correctness', value: 0.94, weight: 'Primary' },\\n          { label: 'Tool safety / adherence', value: 0.90, weight: 'High' },\\n          { label: 'Latency fit', value: 0.86, weight: 'Medium' },\\n          { label: 'Cost efficiency', value: 0.83, weight: 'Medium' },\\n        ],\\n        decisionTrace: [\\n          {\\n            when: 'T+00:00.12s',\\n            event: 'Request classified: code patch intent',\\n            model: 'gpt-5.4-mini',\\n            note: 'Chosen as weighted candidate under Thompson sampling.',\\n          },\\n          {\\n            when: 'T+00:00.41s',\\n            event: 'Beta posterior sampled',\\n            model: 'gpt-5.4-mini',\\n            note: 'Sampled success draw above threshold; route locked.',\\n          },\\n          {\\n            when: 'T+00:00.93s',\\n            event: 'Evaluation signals applied',\\n            model: 'gpt-5.4-mini',\\n            note: 'Safety + correctness rubric satisfied.',\\n          },\\n        ],\\n      },\\n    }\\n  }, [])\\n\\n  const navItems: Array<{ key: PageKey; label: string; desc: string; icon: string }> = [\\n    { key: 'overview', label: 'Overview', desc: 'Command snapshot', icon: '\ud83e\udded' },\\n    { key: 'routing', label: 'Routing Lab', desc: 'Thompson simulator', icon: '\ud83e\uddea' },\\n    { key: 'eval', label: 'Eval Report', desc: 'Results & traces', icon: '\ud83d\udcca' },\\n  ]\\n\\n  const headerSubtitle =\\n    page === 'overview'\\n      ? 'Live routing health, confidence, and cost posture'\\n      : page === 'routing'\\n        ? 'Tune intent routing and inspect model candidate behavior'\\n        : 'Scores, breakdowns, and decision trace for recent runs'\\n\\n  return (\\n    <div className=\\\"appRoot\\\">\\n      <div className=\\\"bgGlow\\\" aria-hidden=\\\"true\\\" />\\n\\n      <div className={`layout ${compactNav ? 'navCompact' : ''}`}>\\n        <aside className=\\\"sidebar\\\" aria-label=\\\"Primary navigation\\\">\\n          <div className=\\\"brand\\\">\\n            <div className=\\\"brandMark\\\" aria-hidden=\\\"true\\\">\\n              <div className=\\\"orb\\\" />\\n              <div className=\\\"orb orb2\\\" />\\n            </div>\\n            <div className=\\\"brandText\\\">\\n              <div className=\\\"brandTitle\\\">Agent Sam</div>\\n              <div className=\\\"brandSubtitle\\\">Command Center</div>\\n            </div>\\n          </div>\\n\\n          <nav className=\\\"nav\\\">\\n            {navItems.map((it, idx) => {\\n              const active = page === it.key\\n              return (\\n                <button\\n                  key={it.key}\\n                  className={`navItem ${active ? 'active' : ''}`}\\n                  onClick={() => setPage(it.key)}\\n                  aria-current={active ? 'page' : undefined}\\n                >\\n                  <div className=\\\"navLeft\\\">\\n                    <div className=\\\"navIcon\\\" aria-hidden=\\\"true\\\">\\n                      {it.icon}\\n                    </div>\\n                    <div className=\\\"navText\\\">\\n                      <div className=\\\"navLabel\\\">{it.label}</div>\\n                      <div className=\\\"navDesc\\\">{it.desc}</div>\\n                    </div>\\n                  </div>\\n                  <div className=\\\"navKbd\\\" aria-hidden=\\\"true\\\">\\n                    {idx + 1}\\n                  </div>\\n                </button>\\n              )\\n            })}\\n          </nav>\\n\\n          <div className=\\\"sidebarFooter\\\">\\n            <div className=\\\"statusRow\\\">\\n              <div className=\\\"dot\\\" />\\n              <div>\\n                <div className=\\\"statusTitle\\\">Routing Engine</div>\\n                <div className=\\\"statusSub\\\">Operational \u2022 Thompson</div>\\n              </div>\\n            </div>\\n            <div className=\\\"tinyHint\\\">Tip: press 1/2/3 to switch pages</div>\\n          </div>\\n        </aside>\\n\\n        <header className=\\\"topbar\\\">\\n          <div className=\\\"topbarLeft\\\">\\n            <div className=\\\"pagePill\\\">\\n              <span className=\\\"pagePillIcon\\\" aria-hidden=\\\"true\\\">\\n                {page === 'overview' ? '\ud83e\udded' : page === 'routing' ? '\ud83e\uddea' : '\ud83d\udcca'}\\n              </span>\\n              <span className=\\\"pagePillText\\\">{navItems.find((n) => n.key === page)?.label}</span>\\n            </div>\\n            <div className=\\\"headerTitle\\\">Agent Sam Command Center</div>\\n            <div className=\\\"headerSubtitle\\\">{headerSubtitle}</div>\\n          </div>\\n\\n          <div className=\\\"topbarRight\\\">\\n            <div className=\\\"searchFake\\\" role=\\\"search\\\">\\n              <div className=\\\"searchIcon\\\" aria-hidden=\\\"true\\\">\\n                \u2315\\n              </div>\\n              <input\\n                className=\\\"searchInput\\\"\\n                placeholder=\\\"Search signals, models, metrics\u2026 (mock)\\\"\\n                onChange={() => void 0}\\n              />\\n            </div>\\n          </div>\\n        </header>\\n\\n        <main className=\\\"main\\\">\\n          {page === 'overview' && (\\n            <>\\n              <section className=\\\"hero\\\">\\n                <div className=\\\"heroGrid\\\">\\n                  <div className=\\\"heroCopy\\\">\\n                    <div className=\\\"heroBadge\\\">Thompson Routing \u2022 Live Health</div>\\n                    <h1 className=\\\"heroH1\\\">Route smarter. Evaluate faster. Ship confidently.</h1>\\n                    <p className=\\\"heroP\\\">\\n                      Agent Sam\u2019s command view summarizes pass outcomes, latency posture, and cost efficiency using a Thompson\\n                      Beta posterior over model candidates.\\n                    </p>\\n\\n                    <div className=\\\"heroActions\\\">\\n                      <button className=\\\"btn primary\\\" onClick={() => setPage('routing')}>\\n                        Open Routing Lab\\n                      </button>\\n                      <button className=\\\"btn ghost\\\" onClick={() => setPage('eval')}>\\n                        View Eval Report\\n                      </button>\\n                    </div>\\n\\n                    <div className=\\\"heroPills\\\">\\n                      <StatPill label=\\\"Posterior conf.\\\" value={`${data.thompson.confidence.toFixed(1)}%`} tone=\\\"good\\\" />\\n                      <StatPill label=\\\"Alpha / Beta\\\" value={`${data.thompson.alpha.toFixed(1)} / ${data.thompson.beta.toFixed(1)}`} tone=\\\"info\\\" />\\n                      <StatPill label=\\\"Best candidate\\\" value={data.thompson.modelCandidates[1].name} tone=\\\"good\\\" />\\n                    </div>\\n                  </div>\\n\\n                  <div className=\\\"heroPanel card\\\">\\n                    <div className=\\\"heroPanelTop\\\">\\n                      <div>\\n                        <div className=\\\"panelTitle\\\">Routing Snapshot</div>\\n                        <div className=\\\"panelSub\\\">Last 15 minutes \u2022 mock telemetry</div>\\n                      </div>\\n                      <div className=\\\"sparkWrap\\\" aria-hidden=\\\"true\\\">\\n                        <div className=\\\"spark\\\" />\\n                        <div className=\\\"spark2\\\" />\\n                      </div>\\n                    </div>\\n\\n                    <div className=\\\"metricsGrid\\\">\\n                      <MetricCard\\n                        title=\\\"Pass rate\\\"\\n                        value={`${data.thompson.passRate.toFixed(1)}%`}\\n                        sub={`${data.thompson.passRateDelta >= 0 ? '+' : ''}${data.thompson.passRateDelta.toFixed(1)}% vs prior`}\\n                        tone={data.thompson.passRateDelta >= 0 ? 'good' : 'warn'}\\n                        icon=\\\"\u2705\\\"\\n                      />\\n                      <MetricCard\\n                        title=\\\"Latency\\\"\\n                        value={formatMs(data.thompson.latencyMs)}\\n                        sub={`${data.thompson.latencyDelta <= 0 ? '' : '+'}${data.thompson.latencyDelta}ms vs prior`}\\n                        tone={data.thompson.latencyDelta <= 0 ? 'good' : 'warn'}\\n                        icon=\\\"\u23f1\ufe0f\\\"\\n                      />\\n                      <MetricCard\\n                        title=\\\"Cost\\\"\\n                        value={`${formatMoney(data.thompson.costPer1k)} / 1k tokens`}\\n                        sub={`${data.thompson.costDelta <= 0 ? '' : '+'}${data.thompson.costDelta.toFixed(2)} vs prior`}\\n                        tone={data.thompson.costDelta <= 0 ? 'good' : 'warn'}\\n                        icon=\\\"\ud83d\udcb8\\\"\\n                      />\\n                      <MetricCard\\n                        title=\\\"Alpha / Beta\\\"\\n                        value={`${data.thompson.alpha.toFixed(1)} / ${data.thompson.beta.toFixed(1)}`}\\n                        sub={`Confidence ${data.thompson.confidence.toFixed(1)}% \u2022 Thompson sampling`}\\n                        tone=\\\"info\\\"\\n                        icon=\\\"\ud83c\udfb2\\\"\\n                      />\\n                    </div>\\n\\n                    <div className=\\\"panelBottom\\\">\\n                      <ProgressBar value={data.thompson.passRate} label=\\\"Success propensity\\\" />\\n                      <div className=\\\"miniRow\\\">\\n                        <div className=\\\"miniKey\\\">Candidates</div>\\n                        <div className=\\\"miniVal\\\">3</div>\\n                        <div className=\\\"miniSpacer\\\" />\\n                        <div className=\\\"miniKey\\\">Policy</div>\\n                        <div className=\\\"miniVal\\\">Weighted Thompson</div>\\n                      </div>\\n                    </div>\\n                  </div>\\n                </div>\\n\\n                <div className=\\\"heroGlowLine\\\" aria-hidden=\\\"true\\\" />\\n              </section>\\n\\n              <section className=\\\"section\\\">\\n                <div className=\\\"sectionHeader\\\">\\n                  <div>\\n                    <div className=\\\"sectionTitle\\\">Model Candidates</div>\\n                    <div className=\\\"sectionSub\\\">A/B-like behavior driven by posterior sampling</div>\\n                  </div>\\n                  <div className=\\\"sectionHint\\\">Includes: gpt-5.3-codex, gpt-5.4-mini, gpt-5.4-nano</div>\\n                </div>\\n\\n                <div className=\\\"cardsGrid\\\">\\n                  {data.thompson.modelCandidates.map((m) => {\\n                    const passTone = m.passRate >= data.thompson.passRate ? 'good' : m.passRate >= data.thompson.passRate - 5 ? 'info' : 'warn'\\n                    return (\\n                      <div key={m.name} className=\\\"card candidate\\\">\\n                        <div className=\\\"candidateTop\\\">\\n                          <div className=\\\"candidateName\\\">{m.name}</div>\\n                          <div className={`chip ${m.flavor}`}>{m.flavor.toUpperCase()}</div>\\n                        </div>\\n                        <div className=\\\"candidateGrid\\\">\\n                          <div className=\\\"candStat\\\">\\n                            <div className=\\\"candLabel\\\">Pass rate</div>\\n                            <div className={`candValue tone-${passTone}`}>{m.passRate.toFixed(1)}%</div>\\n                          </div>\\n                          <div className=\\\"candStat\\\">\\n                            <div className=\\\"candLabel\\\">Latency</div>\\n                            <div className=\\\"candValue\\\">{formatMs(m.latencyMs)}</div>\\n                          </div>\\n                          <div className=\\\"candStat\\\">\\n                            <div className=\\\"candLabel\\\">Cost</div>\\n                            <div className=\\\"candValue\\\">{formatMoney(m.costPer1k)} / 1k</div>\\n                          </div>\\n                        </div>\\n                        <div className=\\\"candidateNotes\\\">{m.notes}</div>\\n                        <div className=\\\"candidateFooter\\\">\\n                          <div className=\\\"sparkMini\\\" aria-hidden=\\\"true\\\" />\\n                          <div className=\\\"candidateFootText\\\">Posterior draws favor higher expected utility.</div>\\n                        </div>\\n                      </div>\\n                    )\\n                  })}\\n                </div>\\n              </section>\\n            </>\\n          )}\\n\\n          {page === 'routing' && (\\n            <>\\n              <section className=\\\"hero heroAlt\\\">\\n                <div className=\\\"heroGrid\\\">\\n                  <div className=\\\"heroCopy\\\">\\n                    <div className=\\\"heroBadge\\\">Routing Lab</div>\\n                    <h1 className=\\\"heroH1\\\">Simulate intent-based routing with Thompson</h1>\\n                    <p className=\\\"heroP\\\">\\n                      Explore how posterior parameters (alpha/beta) shift model preference. This is a mock lab UI with realistic\\n                      shapes and telemetry for Agent Sam.\\n                    </p>\\n                    <div className=\\\"heroActions\\\">\\n                      <button className=\\\"btn primary\\\" onClick={() => setPage('eval')}>\\n                        Jump to Eval\\n                      </button>\\n                      <button className=\\\"btn ghost\\\" onClick={() => setPage('overview')}>\\n                        Back to Overview\\n                      </button>\\n                    </div>\\n                    <div className=\\\"heroPills\\\">\\n                      <StatPill label=\\\"alpha\\\" value={data.thompson.alpha.toFixed(1)} tone=\\\"info\\\" />\\n                      <StatPill label=\\\"beta\\\" value={data.thompson.beta.toFixed(1)} tone=\\\"info\\\" />\\n                      <StatPill label=\\\"confidence\\\" value={`${data.thompson.confidence.toFixed(1)}%`} tone=\\\"good\\\" />\\n                    </div>\\n                  </div>\\n\\n                  <div className=\\\"heroPanel card\\\">\\n                    <div className=\\\"panelTitle\\\">Posterior & Utility</div>\\n                    <div className=\\\"panelSub\\\">Alpha/Beta summary with candidate utility hints</div>\\n\\n                    <div className=\\\"posterior\\\">\\n                      <div className=\\\"posteriorLeft\\\">\\n                        <div className=\\\"posteriorCard\\\">\\n                          <div className=\\\"posteriorK\\\">Posterior draw</div>\\n                          <div className=\\\"posteriorV\\\">p(success) \u2248 {(data.thompson.passRate / 100).toFixed(2)}</div>\\n                          <div className=\\\"posteriorS\\\">Beta(\u03b1={data.thompson.alpha.toFixed(1)}, \u03b2={data.thompson.beta.toFixed(1)})</div>\\n                        </div>\\n                        <div className=\\\"posteriorCard soft\\\">\\n                          <div className=\\\"posteriorK\\\">Utility proxy</div>\\n                          <div className=\\\"posteriorV\\\">E[success] \u2212 latency/cost</div>\\n                          <div className=\\\"posteriorS\\\">Higher utility wins route selection</div>\\n                        </div>\\n                      </div>\\n\\n                      <div className=\\\"posteriorRight\\\">\\n                        <div className=\\\"dist\\\">\\n                          <div className=\\\"distHeader\\\">\\n                            <div className=\\\"distTitle\\\">Success distribution (mock)</div>\\n                            <div className=\\\"distTag\\\">Thompson sample</div>\\n                          </div>\\n                          <div className=\\\"bars\\\" aria-hidden=\\\"true\\\">\\n                            {Array.from({ length: 22 }).map((_, i) => {\\n                              const t = i / 21\\n                              const peak = 0.55\\n                              const width = 0.22\\n                              const val = Math.exp(-Math.pow(t - peak, 2) / (2 * width * width))\\n                              const h = 10 + val * 90\\n                              const grow = i / 21\\n                              return (\\n                                <div\\n                                  key={i}\\n                                  className=\\\"bar\\\"\\n                                  style={{ height: `${h * (0.72 + 0.28 * grow)}%`, opacity: 0.45 + 0.55 * grow }}\\n                                />\\n                              )\\n                            })}\\n                          </div>\\n                          <div className=\\\"distFooter\\\">\\n                            <div className=\\\"distLegend\\\">\\n                              <span className=\\\"legendDot\\\" /> Posterior density (visual)\\n                            </div>\\n                            <div className=\\\"distStat\\\">Pass {data.thompson.passRate.toFixed(1)}%</div>\\n                          </div>\\n                        </div>\\n                      </div>\\n                    </div>\\n                  </div>\\n                </div>\\n              </section>\\n\\n              <section className=\\\"section\\\">\\n                <div className=\\\"sectionHeader\\\">\\n                  <div>\\n                    <div className=\\\"sectionTitle\\\">Scenario Controls</div>\\n                    <div className=\\\"sectionSub\\\">Mock traffic splits with intent targets</div>\\n                  </div>\\n                  <div className=\\\"sectionHint\\\">No external libraries \u2022 pure React + CSS</div>\\n                </div>\\n\\n                <div className=\\\"scenariosGrid\\\">\\n                  {data.routingLab.scenarios.map((s, idx) => {\\n                    const tone = idx === 1 ? 'info' : idx === 0 ? 'good' : 'warn'\\n                    return (\\n                      <div key={s.name} className={`card scenario tone-${tone}`}>\\n                        <div className=\\\"scenarioTop\\\">\\n                          <div className=\\\"scenarioName\\\">{s.name}</div>\\n                          <div className=\\\"scenarioTraffic\\\">{s.traffic}</div>\\n                        </div>\\n                        <div className=\\\"scenarioMeta\\\">\\n                          <div className=\\\"scenarioRow\\\">\\n                            <div className=\\\"scenarioLabel\\\">Target</div>\\n                            <div className=\\\"scenarioVal\\\">{s.target}</div>\\n                          </div>\\n                          <div className=\\\"scenarioRow\\\">\\n                            <div className=\\\"scenarioLabel\\\">Posterior</div>\\n                            <div className=\\\"scenarioVal\\\">\\n                              \u03b1={s.alpha.toFixed(1)} / \u03b2={s.beta.toFixed(1)}\\n                            </div>\\n                          </div>\\n                        </div>\\n                        <div className=\\\"scenarioBars\\\">\\n                          <div className=\\\"scenarioBarRow\\\">\\n                            <div className=\\\"scenarioBarLabel\\\">Expected success</div>\\n                            <div className=\\\"scenarioBarValue\\\">{(data.thompson.passRate / 100 * (0.96 + idx * 0.02) * 100).toFixed(1)}%</div>\\n                          </div>\\n                          <div className=\\\"scenarioBarTrack\\\" aria-hidden=\\\"true\\\">\\n                            <div className=\\\"scenarioBarFill\\\" style={{ width: `${clamp(data.thompson.passRate - 3 + idx * 2, 70, 99)}%` }} />\\n                          </div>\\n                        </div>\\n                        <div className=\\\"scenarioFooter\\\">\\n                          <div className=\\\"scenarioHint\\\">Routing will favor utility-aligned candidates.</div>\\n                        </div>\\n                      </div>\\n                    )\\n                  })}\\n                </div>\\n              </section>\\n\\n              <section className=\\\"section\\\">\\n                <div className=\\\"sectionHeader\\\">\\n                  <div>\\n                    <div className=\\\"sectionTitle\\\">Candidate Router Table</div>\\n                    <div className=\\\"sectionSub\\\">Mock Thompson scores for each model</div>\\n                  </div>\\n                  <div className=\\\"sectionHint\\\">Click a candidate to highlight (mock)</div>\\n                </div>\\n\\n                <RoutingTable candidates={data.thompson.modelCandidates} globalPass={data.thompson.passRate} />\\n              </section>\\n            </>\\n          )}\\n\\n          {page === 'eval' && (\\n            <>\\n              <section className=\\\"hero heroAlt\\\">\\n                <div className=\\\"heroGrid\\\">\\n                  <div className=\\\"heroCopy\\\">\\n                    <div className=\\\"heroBadge\\\">Eval Report</div>\\n                    <h1 className=\\\"heroH1\\\">Quality signals for Agent Sam deployments</h1>\\n                    <p className=\\\"heroP\\\">\\n                      Summary of recent evaluation runs, with decision traces showing how the routing posterior selected\\n                      {` `}\\n                      {data.evalReport.overview.bestModel}.\\n                    </p>\\n\\n                    <div className=\\\"heroActions\\\">\\n                      <button className=\\\"btn primary\\\" onClick={() => setPage('routing')}>\\n                        Inspect Routing Lab\\n                      </button>\\n                      <button className=\\\"btn ghost\\\" onClick={() => setPage('overview')}>\\n                        Back to Overview\\n                      </button>\\n                    </div>\\n"
          }
        ],
