# Copy this file to .env.cloudflare and fill in real values locally.
# Never commit .env.cloudflare.
#
# ── SSOT: platform operator build env ─────────────────────────────────────────
# All local deploy / wrangler / BYOK sync reads through:
#   ./scripts/with-cloudflare-env.sh <command>
#
# Files (gitignored):
#   .env.cloudflare   — this file (real keys)
#   .mcp_exports.sh   — bridge rotation (AGENTSAM_BRIDGE_KEY, MCP_AUTH_TOKEN)
#
# Canonical operator auth_users.id for scripts (must be au_*, NOT person_uuid):
#   OPERATOR_USER_ID=au_871d920d1233cbd1
# Audit:  npm run audit:operator-env
# BYOK:   npm run sync:operator-keys  (.env.cloudflare → dashboard Keys & Secrets)
# ─────────────────────────────────────────────────────────────────────────────

# Canonical platform operator au_* (auth_users.id — see scripts/lib/sam-operator-lane.ids)
# Primary login: info@inneranimals.com → au_871d920d1233cbd1
# Secondary login: sam@inneranimalmedia.com (same operator lane, alternate auth row)
OPERATOR_USER_ID=au_871d920d1233cbd1
D1_AUTH_USER_ID=au_871d920d1233cbd1
IAM_D1_AUTH_USER_ID=au_871d920d1233cbd1
# Primary operator email (login + deploy audit); sam@inneranimalmedia.com is secondary
OPERATOR_USER_EMAIL=info@inneranimals.com
IAM_USER_EMAIL=info@inneranimals.com
# Supabase auth.users UUID — primary login (info@inneranimals.com)
IAM_SUPABASE_USER_ID=6cbd71f8-1d57-4530-9736-9bf03be1adad
# Secondary Supabase auth.users UUID (sam@inneranimalmedia.com backup login)
IAM_SUPABASE_USER_ID_SECONDARY=8678c8bb-b9b2-4aad-bb95-882d27d00787
# Supabase agentsam.agentsam_workspaces.id for ws_inneranimalmedia (Postgres uuid columns)
IAM_SUPABASE_WORKSPACE_ID=fa1f12a8-c841-4b79-a26c-d53a78b17dac
# Optional: resolve by email when OPERATOR_USER_ID unset
# OPERATOR_USER_EMAIL_SECONDARY=sam@inneranimalmedia.com

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# Cloudflare Images hosted API (platform). Separate from Resource Tagging when scopes differ.
# CLOUDFLARE_IMAGES_TOKEN=
# CLOUDFLARE_IMAGES_ACCOUNT_HASH=
#
# Cloudflare Resource Tagging — REQUIRED for Media Library +Add tag to sync to CF.
# Account Owned Token with Tag Read + Tag Write (minted via break-glass / Manage Account API tokens).
# Worker secret: CLOUDFLARE_TAGGING_TOKEN (already used by src/core/cf-resource-tags.js).
# Fallback to CLOUDFLARE_IMAGES_TOKEN / CLOUDFLARE_API_TOKEN only if that token already has Tag Write.
CLOUDFLARE_TAGGING_TOKEN=
# Rotate safely (prompt → verify → write; never prints the token):
#   npm run rotate:cf-api-token
#   npm run rotate:cf-api-token:smoke
# Optional — PTY form defaults on Keys & Secrets (also auto-detected from zones after sync)
# inneranimalmedia.com zone (scripts/cloudflare/install-cache-reserve.sh auto-detects if unset)
# CLOUDFLARE_ZONE_ID=0bab48636c1bea4be4ea61c0c7787c3e
# PTY_TUNNEL_NAME=inneranimalmedia-pty
# PTY_PUBLIC_HOSTNAME=terminal.yourdomain.com
# TERMINAL_WS_URL=https://terminal.yourdomain.com
# D1_DATABASE_ID=   # default D1 for workspace after sync (npm run sync:operator-keys)

# R2 S3 API token (R2 dashboard → Manage R2 API Tokens).
# Used by: deploy-frontend (rclone), scripts/lib/r2-s3-client.mjs, prune/inventory scripts.
# Permissions: at minimum Object Read + Write for buckets you touch; deploy prune also needs Delete.
# NEVER commit .env.cloudflare — it is gitignored (.env.*).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
#
# Production Worker: same keys must exist as Worker secrets (S3 fallback for unbound buckets):
#   ./scripts/with-cloudflare-env.sh npx wrangler secret put R2_ACCESS_KEY_ID -c wrangler.production.toml
#   ./scripts/with-cloudflare-env.sh npx wrangler secret put R2_SECRET_ACCESS_KEY -c wrangler.production.toml
# Verify: ./scripts/check-r2-s3-env.sh

# Supabase — production project ref must be dpmuvynqixblxsilnlut (do not use old/test refs
# such as tcczxkatmodtxfuulvsr or sexdnwlyuhkyvseunqlx in SUPABASE_URL / SUPABASE_FUNCTIONS_URL).
SUPABASE_URL=https://dpmuvynqixblxsilnlut.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_FUNCTIONS_URL=https://dpmuvynqixblxsilnlut.supabase.co/functions/v1
# Dashboard / org owner (NOT an IAM app login — confirmed 2026-07-22 OAuth approval email):
# SUPABASE_DASHBOARD_LOGIN_EMAIL=sam_primeaux@icloud.com
# Org: syccscyruabhkctnpguw  Project: dpmuvynqixblxsilnlut
# Management API personal access token (Account → Access Tokens). Required for
# tools/architecture-cartographer Postgres catalog audit via Management API.
# NOT the service_role key. Create while signed in as sam_primeaux@icloud.com:
#   https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=sbp_...
# Lockout bypass: cartographer falls back to SUPABASE_DB_URL + psycopg2 when PAT unset.

# ── Agent automation: short-lived session cookies (see POST /api/auth/agent-session/mint)
# Store the same value in production:  npx wrangler secret put AGENT_SESSION_MINT_SECRET -c wrangler.production.toml
AGENT_SESSION_MINT_SECRET=
# auth_users.id (au_*) for script session mint — must NOT be person_uuid
AGENT_SESSION_USER_ID=
# Deprecated alias — use OPERATOR_USER_ID or AGENT_SESSION_USER_ID (au_* only)
# AGENT_SESSION_DEFAULT_USER_ID=
# Optional: mint by email instead of id
# AGENT_SESSION_USER_EMAIL=
# Default TTL for minted sessions in scripts (seconds; server caps 60–86400)
# AGENT_SESSION_TTL_SECONDS=900

# Optional: deploy tracking (scripts/deploy.sh → POST /api/deployments/log). Same value as Worker WORKER_SECRET.
# DEPLOY_TRACKING_TOKEN=

# Anthropic — Worker secret + local scripts (e.g. npm run smoke:code-execution-e2e)
ANTHROPIC_API_KEY=
# Optional for smoke: MODEL=sonnet|haiku|opus  OPUS_GATED=true
# Optional row-shape overrides: CODE_EXEC_E2E_WORKSPACE_ID  CODE_EXEC_E2E_TENANT_ID  CODE_EXEC_E2E_USER_ID

# POST /api/test/code-execution-e2e — requires Worker vars (wrangler secret / dashboard):
#   IAM_TEST_SECRET or PTY_AUTH_TOKEN (header X-IAM-Test-Secret)
#   IAM_ENABLE_E2E_TEST_ROUTES=true  (otherwise route returns 404)

# ── Resend (deploy notifications + cron email)
# Worker secrets (production inneranimalmedia worker):
#   npx wrangler secret put RESEND_API_KEY -c wrangler.production.toml
#   npx wrangler secret put RESEND_FROM -c wrangler.production.toml   # verified sender domain
#   npx wrangler secret put RESEND_TO -c wrangler.production.toml     # default notify recipient
RESEND_FROM=notifications@inneranimalmedia.com
RESEND_TO=info@inneranimals.com
DEPLOY_NOTIFY_EMAIL=info@inneranimals.com
# DEPLOY_NOTIFY_EMAIL_SECONDARY=sam@inneranimalmedia.com
# RESEND_API_KEY=   # Resend dashboard → API Keys

# ── Meshy.ai (Design Studio text/image → 3D)
# Dashboard: meshy.ai → Settings → API → create key (format msy-... or msy_...)
# Sync local + Worker (recommended — hidden prompt):
#   ./scripts/sync-meshy-api-key.sh
# From clipboard after copying key in browser:
#   ./scripts/sync-meshy-api-key.sh --paste
# Verify: ./scripts/sync-meshy-api-key.sh --check
# MESHYAI_API_KEY=
# Webhook secret (meshy.ai → Webhooks → Secret): ./scripts/sync-meshy-webhook-secret.sh
# MESHYAI_WEBHOOK_SECRET=

# ── RealtimeKit (Meet v2) — Break Glass for local smoke only; narrow Worker token in production
# Sprint 0 smoke: ./scripts/cloudflare/realtimekit-smoke.sh
# Optional — dedicated zone-scoped token for scripts/cloudflare/install-cache-reserve.sh
# (CLOUDFLARE_BREAK_GLASS_ADMIN_TOKEN cannot write Cache Rules — Realtime Admin only)
# CLOUDFLARE_CACHE_RESERVE_TOKEN=
REALTIMEKIT_APP_ID=08755a39-bfb2-4c6a-b322-527ba7ef0698
# Narrow Realtime Admin (preferred Worker secret — mint via script):
#   ./scripts/cloudflare/mint-realtimekit-api-token.sh --apply
# REALTIMEKIT_API_TOKEN=
# Worker secrets (production):
#   ./scripts/with-cloudflare-env.sh npx wrangler secret put REALTIMEKIT_APP_ID -c wrangler.production.toml
#   ./scripts/with-cloudflare-env.sh npx wrangler secret put REALTIMEKIT_API_TOKEN -c wrangler.production.toml
#   ./scripts/cloudflare/register-realtimekit-webhook.sh --apply-secret
# REALTIMEKIT_WEBHOOK_SECRET=
# REALTIMEKIT_WEBHOOK_URL=https://webhooks.inneranimalmedia.com/api/webhooks/realtimekit
# Optional rollout: MEET_ENGINE=realtimekit in wrangler.production.toml [vars]
# Set Worker secrets: ./scripts/cloudflare/set-realtimekit-worker-secrets.sh
# Prod v2 smoke: AGENT_SESSION_USER_ID=au_... python3 scripts/cloudflare/smoke-meet-v2-prod.py

# ── Web Push (VAPID) — PWA /api/push/* (mirrors Worker secrets)
# Generate: npx web-push generate-vapid-keys
#   ./scripts/with-cloudflare-env.sh npx wrangler secret put VAPID_PUBLIC_KEY -c wrangler.production.toml
#   ./scripts/with-cloudflare-env.sh npx wrangler secret put VAPID_PRIVATE_KEY -c wrangler.production.toml
#   ./scripts/with-cloudflare-env.sh npx wrangler secret put VAPID_SUBJECT -c wrangler.production.toml
# Local wrangler dev: copy VAPID_* into .dev.vars (gitignored)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:sam@inneranimalmedia.com

# ── PUSH_SERVICE_TOKEN — PWA services SW ingest + optional push notify
# Shared bearer for POST https://services.inneranimalmedia.com/api/deploy/ingest
# (scripts/post-services-sw-manifest-ingest.mjs after deploy:fast / deploy:full).
# Also accepted on main worker POST /api/push/notify (with INTERNAL_API_SECRET / AGENTSAM_BRIDGE_KEY).
# Generate once: openssl rand -hex 32
# Same value must exist in all of:
#   1. This file (.env.cloudflare) — Mac deploy:fast sources it
#   2. iam-pwa-services Worker secret:
#        cd ~/iam-pwa-services && npx wrangler secret put PUSH_SERVICE_TOKEN
#   3. Cloudflare Builds → Secrets (so ship:remote / CF Builds run SW ingest)
#   4. Optional main Worker (push notify only):
#        ./scripts/with-cloudflare-env.sh npx wrangler secret put PUSH_SERVICE_TOKEN -c wrangler.production.toml
# Verify local: ./scripts/with-cloudflare-env.sh node scripts/post-services-sw-manifest-ingest.mjs
# Never commit the real value. Never expose to the browser.
# PUSH_SERVICE_TOKEN=

# ── Deploy script auth (scripts/deploy-frontend.sh → POST /api/email/send)
# Must match Worker secret INTERNAL_API_SECRET (Bearer or X-Internal-Secret).
INTERNAL_API_SECRET=

# ── Post-deploy KV + agentsam_hook (scripts/deploy-frontend.sh → POST /api/internal/post-deploy)
# Same value on main worker + inneranimalmedia-mcp-server. Also accepts Bearer on post-deploy.
# Generate/sync: python3 scripts/rotate_mcp_identity.py  (writes .mcp_exports.sh — do not commit)
# source .mcp_exports.sh   # or: source .env.cloudflare after pasting AGENTSAM_BRIDGE_KEY here
AGENTSAM_BRIDGE_KEY=

# ── ExecOS dispatcher / MCP / VM POST /run
# Rotate + sync everywhere: ./scripts/sync-execos-key.sh
# Smoke: ./scripts/test/smoke-execos-chain.sh
EXECOS_KEY=
# SSOT for PTY_AUTH_TOKEN. TERMINAL_SECRET defaults to the same value in install script.
# Sync everywhere: ./scripts/install-terminal-tunnel-env.sh
# See docs/TERMINAL_KEYS_RESET.md
PTY_AUTH_TOKEN=
# TERMINAL_SECRET=          # optional; defaults to PTY_AUTH_TOKEN
# TERMINAL_WS_URL=https://terminal.inneranimalmedia.com
# GitHub CLI on PTY hosts (Mac + GCP): ./scripts/install-terminal-github-cli.sh --prompt-token
# Requires repo-scoped PAT — never commit the value:

# CAD — CF iam-cad-worker container only (no gcp/auto path in code)
# CAD_DISPATCH_TARGET=container
# GITHUB_TOKEN=
# GCP VM (gcloud ssh / env sync)
GCP_PROJECT_ID=
GCP_ZONE=us-central1-f
GCP_VM_NAME=iam-tunnel
# Operator GitHub clone on iam-tunnel (AgentSam remote PTY — NOT Mac, NOT /workspace sandbox)
IAM_GCP_REPO_PATH=/home/samprimeaux/inneranimalmedia
IAM_VM_ENV_REPO_PATHS=/home/samprimeaux/inneranimalmedia
# Tenant sandbox under /workspace (sandboxterminal lane only)
IAM_GCP_WORKSPACES_ROOT=/workspace
# IAM_SANDBOX_TENANT_ID=tenant_sam_primeaux
# IAM_SANDBOX_USER_ID=au_871d920d1233cbd1
# Bootstrap operator VM clone: ./scripts/bootstrap-gcp-vm-repo.sh --sync-env
