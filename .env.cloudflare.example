# Copy this file to .env.cloudflare and fill in real values locally.
# Never commit .env.cloudflare.

CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# R2 S3 API token (R2 dashboard → Manage R2 API Tokens).
# Used by: deploy-frontend (rclone), scripts/lib/r2-s3-client.mjs, prune/inventory scripts.
# Permissions: at minimum Object Read + Write for buckets you touch; deploy prune also needs Delete.
# NEVER commit .env.cloudflare — it is gitignored (.env.*).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
#
# Production Worker: same keys must exist as Worker secrets (S3 fallback for unbound buckets):
#   ./scripts/with-cloudflare-env.sh npx wrangler secret put R2_ACCESS_KEY_ID -c wrangler.production.toml
#   ./scripts/with-cloudflare-env.sh npx wrangler secret put R2_SECRET_ACCESS_KEY -c wrangler.production.toml
# Verify: ./scripts/check-r2-s3-env.sh

# Supabase — production project ref must be dpmuvynqixblxsilnlut (do not use old/test refs
# such as tcczxkatmodtxfuulvsr or sexdnwlyuhkyvseunqlx in SUPABASE_URL / SUPABASE_FUNCTIONS_URL).
SUPABASE_URL=https://dpmuvynqixblxsilnlut.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_FUNCTIONS_URL=https://dpmuvynqixblxsilnlut.supabase.co/functions/v1

# ── Agent automation: short-lived session cookies (see POST /api/auth/agent-session/mint)
# Store the same value in production:  npx wrangler secret put AGENT_SESSION_MINT_SECRET -c wrangler.production.toml
AGENT_SESSION_MINT_SECRET=
# auth_users.id for scripts/smoke_agent_e2e.py when minting (optional if you set AGENT_SESSION_DEFAULT_USER_ID on the Worker)
AGENT_SESSION_USER_ID=
# Optional: mint by email instead of id
# AGENT_SESSION_USER_EMAIL=
# Default TTL for minted sessions in scripts (seconds; server caps 60–86400)
# AGENT_SESSION_TTL_SECONDS=900

# Anthropic — Worker secret + local scripts (e.g. npm run smoke:code-execution-e2e)
ANTHROPIC_API_KEY=
# Optional for smoke: MODEL=sonnet|haiku|opus  OPUS_GATED=true
# Optional row-shape overrides: CODE_EXEC_E2E_WORKSPACE_ID  CODE_EXEC_E2E_TENANT_ID  CODE_EXEC_E2E_USER_ID

# POST /api/test/code-execution-e2e — requires Worker vars (wrangler secret / dashboard):
#   IAM_TEST_SECRET or PTY_AUTH_TOKEN (header X-IAM-Test-Secret)
#   IAM_ENABLE_E2E_TEST_ROUTES=true  (otherwise route returns 404)
