/**
 * Inner Animal Media — Dashboard Worker Configuration (Sandbox)
 *
 * Bindings match exactly what is live in the Cloudflare dashboard.
 *
 * Secrets (wrangler secret put):
 *   ANTHROPIC_API_KEY, GITHUB_TOKEN, OPENAI_API_KEY, GOOGLE_AI_API_KEY
 *   CLOUDFLARE_API_TOKEN, R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY
 *   AI_SEARCH_TOKEN, DEPLOY_TRACKING_TOKEN, GEMINI_API_KEY
 */

{
  "$schema": "https://raw.githubusercontent.com/cloudflare/wrangler2/main/packages/wrangler/config-schema.json",
  "name": "inneranimal-dashboard",
  "main": "src/index.js",
  "compatibility_date": "2026-01-20",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "preview_urls": true,

  "build": {
    "command": ""
  },

  "routes": [
    {
      "pattern": "sandbox.inneranimalmedia.com",
      "zone_name": "inneranimalmedia.com",
      "custom_domain": true
    }
  ],

  "ai": {
    "binding": "AI"
  },

  "browser": {
    "binding": "MYBROWSER"
  },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "inneranimalmedia-business",
      "database_id": "cf87b717-d4e2-4cf8-bab0-a81268e32d49"
    }
  ],

  "r2_buckets": [
    { "binding": "ASSETS",        "bucket_name": "inneranimalmedia" },
    { "binding": "DASHBOARD",     "bucket_name": "inneranimalmedia" },
    { "binding": "AUTORAG_BUCKET","bucket_name": "inneranimalmedia-autorag" },
    { "binding": "DOCS_BUCKET",   "bucket_name": "iam-docs" },
    { "binding": "R2",            "bucket_name": "iam-platform" },
    { "binding": "TOOLS",         "bucket_name": "tools" }
  ],

  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "08183bb9d2914e87ac8395d7e4ecff60"
    }
  ],

  "vectorize": [
    {
      "binding": "VECTORIZE",
      "index_name": "ai-search-inneranimalmedia-autorag"
    }
  ],

  "kv_namespaces": [
    { "binding": "KV",            "id": "09438d5e4f664bf78467a15af7743c44" },
    { "binding": "SESSION_CACHE", "id": "dc87920b0a9247979a213c09df9a0234" }
  ],

  "durable_objects": {
    "bindings": [
      { "name": "AGENT_SESSION", "class_name": "AgentChatSqlV1" },
      { "name": "CHESS_SESSION", "class_name": "ChessRoom" },
      { "name": "IAM_COLLAB",    "class_name": "IAMCollaborationSession" }
    ]
  },

  "migrations": [
    { "tag": "v4", "new_sqlite_classes": ["IAMAgentSession"] },
    { "tag": "v5", "new_sqlite_classes": ["AgentChatSqlV1"] },
    { "tag": "v6", "deleted_classes": ["IAMSession", "IAMAgentSession"] }
  ],

  "analytics_engine_datasets": [
    { "binding": "WAE", "dataset": "inneranimalmedia" }
  ],

  "triggers": {
    "crons": [
      "0 6 * * *",
      "30 13 * * *",
      "0 9 * * *",
      "*/30 * * * *",
      "0 0 * * *"
    ]
  },

  "vars": {
    "CLOUDFLARE_ACCOUNT_ID":          "ede6590ac0d2fb7daf155b35653457b2",
    "CLOUDFLARE_IMAGES_ACCOUNT_HASH": "g7wf09fCONpnidkRnR_5vw",
    "GITHUB_CLIENT_ID":               "Ov23li6BZYxjVtGUWibX",
    "GOOGLE_CLIENT_ID":               "427617292678-gf3u47lpf876q7miq31hel2ms6tcr2f8.apps.googleusercontent.com",
    "TENANT_ID":                      "tenant_sam_primeaux",
    "WORKSPACE_ID":                   "ws_sandbox",
    "DEPLOY_ENV":                     "sandbox",
    "IAM_ORIGIN":                     "https://inneranimal-dashboard.meauxbility.workers.dev",
    "SANDBOX_SIGNIN_FALLBACK_URL":    "https://pub-0d103dec19f84813ab2d58b17153a95f.r2.dev/static/auth-signin.html",
    "VITE_LOGO_URL":                  "https://imagedelivery.net/g7wf09fCONpnidkRnR_5vw/ac515729-af6b-4ea5-8b10-e581a4d02100/thumbnail",
    "VITE_PRODUCT_LABEL":             "Inner Animal Media — Agent Sam",
    "VITE_SHELL_VERSION":             "v1",
    "VITE_API_BASE":                  "https://inneranimalmedia.com",
    "VITE_DASHBOARD_URL":             "https://inneranimal-dashboard.meauxbility.workers.dev"
  },

  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": true,
      "persist": true,
      "head_sampling_rate": 1
    }
  },

  "tail_consumers": [
    { "service": "inneranimalmedia-tail" }
  ]
}
