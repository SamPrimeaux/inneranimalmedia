{
  "name": "inneranimalmedia",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:report-upload": "playwright test && ./scripts/upload-playwright-report-to-r2.sh",
    "theme-debug": "node scripts/theme-debug-playwright.mjs",
    "theme-debug:headed": "HEADED=1 node scripts/theme-debug-playwright.mjs",
    "theme-debug:upload": "node scripts/theme-debug-playwright.mjs --upload-r2",
    "start": "node server.js",
    "deploy": "./scripts/with-cloudflare-env.sh npx wrangler deploy -c wrangler.production.toml",
    "deploy:worker": "./scripts/with-cloudflare-env.sh npx wrangler deploy -c wrangler.production.toml",
    "deploy:frontend": "bash scripts/deploy-frontend.sh",
    "generate:route-map": "node scripts/generate-route-map.js",
    "build:codebase-priority": "node scripts/build-index-priority-files.mjs",
    "ingest:docs": "./scripts/with-cloudflare-env.sh node scripts/ingest-docs.js",
    "ingest:d1-memory": "./scripts/with-cloudflare-env.sh node scripts/ingest-d1-memory.js",
    "reingest:supabase-documents:dry-run": "./scripts/with-cloudflare-env.sh node scripts/reingest-supabase-documents.mjs --dry-run",
    "reingest:supabase-documents:apply": "./scripts/with-cloudflare-env.sh node scripts/reingest-supabase-documents.mjs --apply",
    "verify:supabase-documents": "./scripts/with-cloudflare-env.sh node scripts/verify-supabase-documents.mjs",
    "smoke:supabase-documents-dry-run": "./scripts/with-cloudflare-env.sh node scripts/reingest-supabase-documents.mjs --dry-run --verbose",
    "r2:inventory:inneranimalmedia": "./scripts/with-cloudflare-env.sh node scripts/inventory-r2-bucket.mjs --bucket inneranimalmedia",
    "r2:inventory:upsert": "./scripts/with-cloudflare-env.sh node scripts/inventory-r2-bucket.mjs --bucket inneranimalmedia --upsert-d1",
    "r2:inventory:autorag": "./scripts/with-cloudflare-env.sh node scripts/inventory-r2-bucket.mjs --bucket autorag",
    "r2:inventory:leadership-legacy": "./scripts/with-cloudflare-env.sh node scripts/inventory-r2-bucket.mjs --bucket leadership-legacy --tenant-id tenant_connor_mcneely --workspace-id ws_connor_mcneely --project-id leadership-legacy --edited-by au_5d17673408aaebc7",
    "r2:deploy-manifest": "node scripts/build-r2-deploy-manifest.mjs --dist dashboard/dist --bucket inneranimalmedia --prefix static/dashboard/app --deploy-id manual_manifest",
    "r2:manifest-reconcile:dry-run": "node scripts/r2-dashboard-manifest-reconcile.mjs --dist dashboard/dist --bucket inneranimalmedia --prefix static/dashboard/app --dry-run",
    "r2:upload:dashboard-app-prod": "./scripts/upload-dashboard-app-r2-prod.sh",
    "r2:prune:dry-run": "node scripts/prune-r2-orphans.mjs --dry-run --bucket inneranimalmedia --tenant-id tenant_sam_primeaux --workspace-id ws_inneranimalmedia --project-id inneranimalmedia",
    "r2:prune:apply": "node scripts/prune-r2-orphans.mjs --apply --bucket inneranimalmedia --tenant-id tenant_sam_primeaux --workspace-id ws_inneranimalmedia --project-id inneranimalmedia",
    "r2:prune": "node scripts/run-with-agentsam-script-telemetry.mjs --script-id script_connor_r2_prune --workspace-id ws_inneranimalmedia --triggered-by deploy-full -- npm run r2:prune:apply",
    "deploy:full": "./scripts/deploy-full.sh",
    "deploy:full:safe": "npm run deploy:full",
    "deploy:ledger:start": "node scripts/record-supabase-deploy-start.mjs",
    "deploy:ledger:complete": "node scripts/record-supabase-deploy-complete.mjs",
    "deploy:ledger:failure": "node scripts/record-supabase-deploy-failure.mjs",
    "deploy:ledger:finalize-stale": "./scripts/with-cloudflare-env.sh node scripts/finalize-stale-deploy-events.mjs --mode=manual --older-than-minutes=30 --apply",
    "deploy:ledger:finalize-stale:dry-run": "./scripts/with-cloudflare-env.sh node scripts/finalize-stale-deploy-events.mjs --mode=manual --older-than-minutes=30 --dry-run",
    "cron:finalize-stale-deploys": "./scripts/with-cloudflare-env.sh node scripts/finalize-stale-deploy-events.mjs --mode=manual --older-than-minutes=30 --apply",
    "cron:finalize-stale-deploys:dry-run": "./scripts/with-cloudflare-env.sh node scripts/finalize-stale-deploy-events.mjs --mode=manual --older-than-minutes=30 --dry-run",
    "cron:runs:recent": "./scripts/with-cloudflare-env.sh npx wrangler d1 execute inneranimalmedia-business --remote -c wrangler.production.toml --command \"SELECT job_name, status, tenant_id, workspace_id, rows_read, rows_written, error_message, datetime(started_at,'unixepoch') AS started_at, datetime(completed_at,'unixepoch') AS completed_at, duration_ms FROM agentsam_cron_runs ORDER BY started_at DESC LIMIT 25\"",
    "audit:tenant-workspace:repo": "python3 scripts/audit_tenant_workspace_hardcoding.py --repo-only",
    "audit:tenant-workspace:d1": "./scripts/with-cloudflare-env.sh python3 scripts/audit_tenant_workspace_hardcoding.py --remote --wrangler-config wrangler.production.toml --database inneranimalmedia-business",
    "deploy:d1:start": "./scripts/with-cloudflare-env.sh node scripts/record-d1-deploy-start.mjs",
    "deploy:d1:complete": "./scripts/with-cloudflare-env.sh node scripts/record-d1-deploy-complete.mjs",
    "deploy:d1:failure": "./scripts/with-cloudflare-env.sh node scripts/record-d1-deploy-failure.mjs",
    "deploy:health:verify": "./scripts/with-cloudflare-env.sh node scripts/record-d1-deployment-health.mjs",
    "deploy:index-codebase": "node scripts/index-codebase-snapshot.mjs --apply",
    "deploy:eval": "node scripts/run-deploy-eval.mjs",
    "promote:prod": "./scripts/promote-to-prod.sh",
    "smoke:ai": "node scripts/ai-smoke-report.mjs",
    "smoke:mcp": "node scripts/mcp-smoke.mjs",
    "smoke:code-execution-e2e": "node scripts/test-code-execution-e2e.mjs",
    "smoke:post-deploy": "./scripts/post-deploy-smoke.sh",
    "verify:agentsam-telemetry": "./scripts/verify-agentsam-telemetry-after-deploy.sh",
    "smoke:mcp-actor": "node scripts/mcp-actor-authorization-smoke.mjs",
    "smoke:workflow-runs:seed": "./scripts/with-cloudflare-env.sh node scripts/seed-agentsam-workflow-runs.mjs",
    "smoke:workflow-runs:http": "./scripts/with-cloudflare-env.sh node scripts/run-workflow-start-batch.mjs",
    "d1:workflows-audit": "./scripts/with-cloudflare-env.sh npx wrangler d1 execute inneranimalmedia-business --remote -c wrangler.production.toml --file=./scripts/d1-workflows-audit.sql",
    "designstudio:check": "bash scripts/designstudio/local-check.sh",
    "designstudio:smoke": "bash scripts/designstudio/pipeline-smoke.sh",
    "build": "npm run build:vite-only && node scripts/bump-cache.js",
    "build:vite-only": "npm --prefix dashboard run build",
    "dev:dashboard": "npm --prefix dashboard run dev",
    "preview:dashboard": "npm --prefix dashboard run preview",
    "agentsam:scripts:register:dry-run": "./scripts/with-cloudflare-env.sh node scripts/register-agentsam-scripts.mjs --dry-run",
    "agentsam:scripts:register": "./scripts/with-cloudflare-env.sh node scripts/register-agentsam-scripts.mjs --apply",
    "agentsam:scripts:upload-r2:dry-run": "./scripts/with-cloudflare-env.sh node scripts/upload-agentsam-shell-scripts-r2.mjs --dry-run",
    "agentsam:scripts:upload-r2": "./scripts/with-cloudflare-env.sh node scripts/upload-agentsam-shell-scripts-r2.mjs",
    "theme:package": "node scripts/themes/generate-theme-package.mjs",
    "theme:preview": "node scripts/themes/generate-theme-previews.mjs",
    "theme:preview:all": "node scripts/themes/generate-theme-previews.mjs --all-active",
    "theme:preview:upload": "node scripts/themes/generate-theme-previews.mjs --all-active --upload-r2 --remote",
    "smoke:agentsam:r2-env": "bash -lc 'source scripts/load-agentsam-env.sh && SMOKE_ID=r2_env_smoke_$(date +%Y%m%d_%H%M%S) && SMOKE_KEY=$AGENTSAM_R2_RESULTS_PREFIX/$SMOKE_ID.json && mkdir -p tmp/r2-smoke && printf \"{\\\"smoke_id\\\":\\\"$SMOKE_ID\\\",\\\"bucket\\\":\\\"$AGENTSAM_R2_BUCKET\\\",\\\"key\\\":\\\"$SMOKE_KEY\\\",\\\"workspace_id\\\":\\\"$IAM_WORKSPACE_ID\\\",\\\"tenant_id\\\":\\\"$IAM_TENANT_ID\\\",\\\"user_id\\\":\\\"$IAM_USER_ID\\\",\\\"created_at\\\":\\\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\\\",\\\"purpose\\\":\\\"validate Agent Sam R2 env target\\\"}\\n\" > tmp/r2-smoke/$SMOKE_ID.json && npx wrangler r2 object put \"$AGENTSAM_R2_BUCKET/$SMOKE_KEY\" --file tmp/r2-smoke/$SMOKE_ID.json --remote && npx wrangler r2 object get \"$AGENTSAM_R2_BUCKET/$SMOKE_KEY\" --file tmp/r2-smoke/$SMOKE_ID.readback.json --remote && cat tmp/r2-smoke/$SMOKE_ID.readback.json | jq'",
    "deploy:full:reconcile": "./scripts/deploy-full.sh"
  },
